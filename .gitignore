# User media files — scope to output/temp only, NOT root (icon.png must be tracked)
app/output/**/*.png
app/output/**/*.jpg
app/output/**/*.jpeg
app/output/**/*.mp4
app/output/**/*.webm
app/output/**/*.webp
app/output/**/*.avi
app/output/**/*.mkv
app/temp/**/*.png
app/temp/**/*.jpg
app/temp/**/*.jpeg
app/temp/**/*.mp4
